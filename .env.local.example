# Local development — copy this file to .env.local and fill in values.
# Supabase: Dashboard → Project Settings → API → Project URL and anon/public key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: public site URL (no trailing slash). Improves Open Graph / canonical URLs when not inferred from Vercel, e.g. https://schedule.example.com
# NEXT_PUBLIC_SITE_URL=
