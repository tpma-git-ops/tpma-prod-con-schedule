# Local development — copy this file to .env.local and fill in values.
# Supabase: Dashboard → Project Settings → API → Project URL and anon/public key.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical public site URL, no trailing slash.
# In production, set this to the exact domain allowed in Supabase Auth redirect URLs.
# Example: https://toronto-product-conference-schedule.vercel.app
# NEXT_PUBLIC_SITE_URL=
